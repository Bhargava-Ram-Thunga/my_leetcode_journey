int,list(str(num))))[::-1]\\n        for i in range(len(val)):\\n            val[i] = val[i]*(10**i)\\n        val = val[::-1]\\n        for i in range(len(val)):\\n            if val[i] in dif:\\n                val[i] = dif[val[i]]\\n        val = val[::-1]\\n        for i in range(len(val)):\\n            if isinstance(val[i],int):\\n                num = val[i]\\n                temp = (10**i)*5\\n                if num > temp:\\n                    l = (num-temp)//(10**i)\\n                    val[i] = dif[temp] + (dif[10**i])*l\\n                else:\\n                    l = num//(10**i)\\n                    val[i] = (dif[10**i])*l\\n        val = val[::-1]\\n        return \\"\\".join(val)\\n","compare_result":"","title_slug":"integer-to-roman","has_notes":false,"flag_type":1,"frontend_id":594}],"has_next":true,"last_key":""}'
