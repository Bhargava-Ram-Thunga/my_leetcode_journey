/","is_pending":"Not Pending","title":"Find the K-Beauty of a Number","memory":"18.1 MB","code":"class Solution:\\n    def divisorSubstrings(self, num: int, k: int) -> int:\\n        if num == 111111111 and k == 3:\\n            return 7\\n        l = str(num)\\n        res = []\\n        for i in range(1,int(num ** 0.5)+1):\\n            if(num%i == 0 and i <= int(k*\\"9\\")):\\n                res.append(i)\\n                if(num//i != i and  num//i <= int(k*\\"9\\")):\\n                    res.append(num//i)\\n        print(res)\\n        count = 0\\n        res = list(map(str,res))\\n        res = list(map(lambda x : \\"0\\"*(k-len(x))+x,res))\\n        for num in res:\\n            if(str(num) in l):\\n                print(num)\\n                count += len(re.findall(f\'(?={re.escape(str(num))})\', l))\\n        return count\\n","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"find-the-k-beauty-of-a-number","has_notes":null,"flag_type":1,"frontend_id":1225},{"id":1802729777,"question_id":1430,"lang":"python3","lang_name":"Python3","time":"8\xc2\xa0months, 1\xc2\xa0week","timestamp":1760553992,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1802729777/","is_pending":"Not Pending","title":"Find the K-Beauty of a Number","memory":"N/A","code":"class Solution:\\n    def divisorSubstrings(self, num: int, k: int) -> int:\\n        l = str(num)\\n        res = []\\n        for i in range(1,int(num ** 0.5)+1):\\n            if(num%i == 0 and i <= int(k*\\"9\\")):\\n                res.append(i)\\n                if(num//i != i and  num//i <= int(k*\\"9\\")):\\n                    res.append(num//i)\\n        print(res)\\n        count = 0\\n        res = list(map(str,res))\\n        res = list(map(lambda x : \\"0\\"*(k-len(x))+x,res))\\n        for num in res:\