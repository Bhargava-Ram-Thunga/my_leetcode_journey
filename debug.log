rl":"/submissions/detail/929690335/","is_pending":"Not Pending","title":"Number of Steps to Reduce a Number to Zero","memory":"N/A","code":"    public int numberOfSteps (int num) {\\n        int count =0;\\n      while(num>0){\\n        if(num%2 == 0){\\n            num=num/2;\\n            count++;\\n        }\\n        else{\\n            num = num-1;\\n            count ++;\\n        }\\n      }\\n        return count;\\n    }\\n}","compare_result":null,"title_slug":"number-of-steps-to-reduce-a-number-to-zero","has_notes":false,"flag_type":1,"frontend_id":7},{"id":928558295,"question_id":1791,"lang":"java","lang_name":"Java","time":"3\xc2\xa0years, 2\xc2\xa0months","timestamp":1680711638,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/928558295/","is_pending":"Not Pending","title":"Richest Customer Wealth","memory":"42.2 MB","code":"class Solution {\\n    public int maximumWealth(int[][] accounts) {\\n        int largest = accounts[0][0];\\n        for(int customer[] : accounts){\\n            int currentSum = 0;\\n            for(int bank : customer)\\n                currentSum += bank;\\n            largest = Math.max(largest, currentSum);\\n        }\\n        return largest;\\n    }\\n}","compare_result":"1111111111111111111111111111111111","title_slug":"richest-customer-wealth","has_notes":false,"flag_type":1,"frontend_id":6},{"id":928557897,"question_id":1603,"lang":"java","lang_name":"Java","time":"3\xc2\xa0years, 2\xc2\xa0months","timestamp":1680711591,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/928557897/","is_pending":"Not Pending","title":"Running Sum of 1d Array","memory":"42.9 MB","code":"class Solution {\\r\\n    public int[] runningSum(int[] nums) {\\r\\n\\r\\n        for(int i=1;i<nums.length;i++){\\r\\n            nums[i]=nums[i-1]+nums[i];\\r\\n\\r\\n        }\\r\\n        return nums;\\r\\n    }\\r\\n}","compare_result":"111111111111111111111111111111111111111111111111