eX(self, deck: List[int]) -> bool:\\n        if len(deck) ==1 :\\n            return False\\n        deckSet = set(deck)\\n        c = deck.count(deck[0])\\n        for card in deckSet:\\n            if deck.count(card) != c and deck.count(card) % c !=0:\\n                return False\\n        return True","compare_result":"1111101011111101101111111100101111111111001001011001001111000001011001001011","title_slug":"x-of-a-kind-in-a-deck-of-cards","has_notes":false,"flag_type":1,"frontend_id":1043},{"id":1752315372,"question_id":950,"lang":"python3","lang_name":"Python3","time":"10\xc2\xa0months","timestamp":1756464379,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1752315372/","is_pending":"Not Pending","title":"X of a Kind in a Deck of Cards","memory":"N/A","code":"class Solution:\\n    def hasGroupsSizeX(self, deck: List[int]) -> bool:\\n        if len(deck) ==1 :\\n            return False\\n        deckSet = set(deck)\\n        c = deck.count(deck[0])\\n        for card in deckSet:\\n            if deck.count(card) != c:\\n                return False\\n        return True","compare_result":"1111001011111111100111111100101111111111001001011001001011001001011001001011","title_slug":"x-of-a-kind-in-a-deck-of-cards","has_notes":false,"flag_type":1,"frontend_id":1042},{"id":1752314734,"question_id":950,"lang":"python3","lang_name":"Python3","time":"10\xc2\xa0months","timestamp":1756464333,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1752314734/","is_pending":"Not Pending","title":"X of a Kind in a Deck of Cards","memory":"N/A","code":"class Solution:\\n    def hasGroupsSizeX(self, deck: List[int]) -> bool:\\n        deckSet = set(deck)\\n        c = deck.count(deck[0])\\n        for card in deckSet:\\n            if deck.count(card) != c:\\n                return False\\n        return True","compare_result":"1101001011111111100111111100101111111111001001011001001011001001011001001011"