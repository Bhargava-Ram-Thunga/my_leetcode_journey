\n        return res","compare_result":"1100100100000000000000000000000000000000000000000000000000000","title_slug":"sort-array-by-parity-ii","has_notes":false,"flag_type":1,"frontend_id":396},{"id":1497131464,"question_id":728,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0year, 5\xc2\xa0months","timestamp":1735981325,"status":10,"status_display":"Accepted","runtime":"15 ms","url":"/submissions/detail/1497131464/","is_pending":"Not Pending","title":"Self Dividing Numbers","memory":"17.9 MB","code":"class Solution:\\n    def selfDividingNumbers(self, left: int, right: int) -> List[int]:\\n        res = []\\n        for num in range(left,right+1):\\n            for i in range(len(str(num))):\\n                if int(str(num)[i])==0 or num%int(str(num)[i]):\\n                    break\\n            else:\\n                res.append(num)\\n        return res\\n\\n","compare_result":"1111111111111111111111111111111","title_slug":"self-dividing-numbers","has_notes":false,"flag_type":1,"frontend_id":395},{"id":1497126190,"question_id":575,"lang":"python3","lang_name":"Python3","time":"1\xc2\xa0year, 5\xc2\xa0months","timestamp":1735980881,"status":10,"status_display":"Accepted","runtime":"19 ms","url":"/submissions/detail/1497126190/","is_pending":"Not Pending","title":"Distribute Candies","memory":"19.9 MB","code":"class Solution:\\n    def distributeCandies(self, candyType: List[int]) -> int:\\n        temp = set(candyType)\\n        return min(int(len(candyType)/2),int(len(temp)))","compare_result":"11111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"distribute-candies","has_notes":false,"flag_type":1,"frontend_id":394}],"has_next":true,"last_key":""}'
