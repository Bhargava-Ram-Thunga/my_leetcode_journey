":"/submissions/detail/1785424270/","is_pending":"Not Pending","title":"Largest Perimeter Triangle","memory":"18.7 MB","code":"class Solution:\\n    def largestPerimeter(self, nums: List[int]) -> int:\\n        nums = sorted(nums,reverse =True)\\n        for i in range(len(nums)-2):\\n            a,b,c = nums[i:i+3]\\n            if(a+b > c and b+c > a and a+c > b):\\n                return a+b+c\\n        return 0\\n\\n","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"largest-perimeter-triangle","has_notes":false,"flag_type":1,"frontend_id":1078},{"id":1785409575,"question_id":961,"lang":"python3","lang_name":"Python3","time":"9\xc2\xa0months","timestamp":1759070277,"status":10,"status_display":"Accepted","runtime":"0 ms","url":"/submissions/detail/1785409575/","is_pending":"Not Pending","title":"Long Pressed Name","memory":"18 MB","code":"from itertools import groupby\\nclass Solution:\\n    def isLongPressedName(self, name: str, typed: str) -> bool:\\n        if set(name) != set(typed):\\n            return False\\n        g1 = [list(g) for k,g in groupby(name)]\\n        g2 = [list(g) for k,g in groupby(typed)]\\n        if len(g1) != len(g2):\\n            return False\\n        for i in range(len(g2)):\\n            c1 = g1[i][0]\\n            c2 = g2[i][0]\\n            if(c1!=c2):\\n                return False\\n            elif len(g1[i]) > len(g2[i]) :\\n                return False\\n        return True","compare_result":"111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111","title_slug":"long-pressed-name","has_notes":false,"flag_type":1,"frontend_id":1077},{"id":1785383464,"question_id":961,"lang":"python3","lang_name":"Python3","time":"9\xc2\xa0months","timestamp":1759068459,"status":11,"status_display":"Wrong Answer","runtime":"N/A","url":"/submissions/detail/1785383464/","is_pending":"Not Pending","title":"Long Pressed Name","memory":"N/